# Cloudflare R2 (rclone remote name + bucket)
BACKUP_RCLONE_REMOTE=r2:quant-backup

# Optional: auto-generate /root/.config/rclone/rclone.conf via scripts/configure-rclone.sh
# BACKUP_R2_ACCOUNT_ID=your_cloudflare_account_id
# BACKUP_R2_ACCESS_KEY_ID=your_r2_access_key_id
# BACKUP_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# GPG symmetric encryption for secrets bundle
BACKUP_GPG_PASSPHRASE=change_me_strong_passphrase

# TradingJournal Supabase Postgres (direct :5432 or pooler :6543)
JOURNAL_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Telegram alerts (errors only)
BACKUP_TELEGRAM_BOT_TOKEN=
BACKUP_TELEGRAM_CHAT_ID=

# Retention (days)
BACKUP_RETAIN_DAILY_DAYS=30
BACKUP_RETAIN_WEEKLY_DAYS=365

# Optional overrides
# BACKUP_TMP_DIR=/tmp/quant-backup
# BACKUP_LOG_DIR=/var/log/quant-backup
